{
  "name": "dermanube",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "Aplicacion/ServicioPersonas",
    "Aplicacion/ServicioCitas",
    "Aplicacion/TrabajadorDocumentos"
  ],
  "scripts": {
    "instalar": "npm install",
    "probar": "npm run probar --workspaces --if-present",
    "iniciarPersonas": "npm --workspace Aplicacion/ServicioPersonas run iniciar",
    "iniciarCitas": "npm --workspace Aplicacion/ServicioCitas run iniciar",
    "iniciarTrabajador": "npm --workspace Aplicacion/TrabajadorDocumentos run iniciar",
    "test": "npm run probar --workspaces --if-present"
  }
}
